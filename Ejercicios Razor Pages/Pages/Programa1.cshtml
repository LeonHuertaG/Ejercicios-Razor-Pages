@page
@model Ejercicios_Razor_Pages.Pages.IMCModel
@{
}

<h1>Calculadora de IMC</h1>

<form method="post">
    <label>Peso en kg:</label>
    <input type="number" step="0.01" asp-for="Peso" required />

    <br /><br />

    <label>Altura en metros:</label>
    <input type="number" step="0.01" asp-for="Altura" required />

    <br /><br />

    <button type="submit">Calcular IMC</button>
</form>

@if (Model.ResultadoCalculado)
{
    <hr />

    <h2>Resultado</h2>

    <p><strong>IMC:</strong> @Model.IMC.ToString("0.00")</p>
    <p><strong>Clasificación:</strong> @Model.Clasificacion</p>
    <p><strong>Recomendación:</strong> @Model.Recomendacion</p>

    <img src="@Model.Imagen"
         alt="@Model.Clasificacion"
         width="300" />
}